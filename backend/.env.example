# ══════════════════════════════════════════
#  ARMY BATTLEFIELD MONITORING SYSTEM
#  Backend Environment Configuration
#  Copy this file to .env and fill in values
# ══════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — fill in YOUR database credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=army_bfms
DB_USER=postgres
DB_PASSWORD=your_password_here

# OR use a full connection string (overrides above if set)
# DATABASE_URL=postgresql://user:password@host:5432/army_bfms

# CORS — your Angular app URL
CORS_ORIGIN=http://localhost:4200

# WebSocket ping interval (ms)
WS_PING_INTERVAL=30000
